# plugin-alexa environment
# For local discovery mode, only PLUGIN_DATA_DIR is required.
# Full functionality requires Alexa relay configuration.
# Copy to .env.local and customize with real values.

# Required: Directory for plugin state storage
PLUGIN_DATA_DIR=/tmp/plugin-alexa

# Optional: Plugin settings
PLUGIN_ALEXA_ENABLED=true
PLUGIN_ALEXA_LOG_LEVEL=info

# Optional: Alexa relay configuration (required for Alexa control)
# ALEXA_RELAY_WS_ENDPOINT=wss://relay.example.com
# ALEXA_RELAY_CLIENT_ID=your_client_id
# ALEXA_RELAY_CLIENT_SECRET=your_client_secret
# ALEXA_RELAY_TOKEN=your_relay_token
